# ─── Base de datos (Neon) ───────────────────────────────────────────────
# Cadena de conexión que te da Neon (usa la "pooled connection" / con sslmode=require)
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST/NOMBRE_DB?sslmode=require"

# ─── Sesiones ───────────────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión. Genera uno con:
#   openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# ─── Super-administrador fijo ───────────────────────────────────────────
# Usuario del super-admin (el que gestiona todo)
ADMIN_USERNAME="admin"
# Hash bcrypt de la contraseña del admin. Genera el hash con:
#   npm run hash -- "TuContraseñaSegura"
ADMIN_PASSWORD_HASH=""
