# ─── Base de datos (Neon / Vercel Postgres) ─────────────────────────────
# Cadena de conexión (usa la "pooled", con sslmode=require)
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST/NOMBRE_DB?sslmode=require"

# ─── Sesiones ───────────────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión. Genera uno con:
#   openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# ─── Super-administrador fijo ───────────────────────────────────────────
# Usuario del super-admin (el que gestiona todo)
ADMIN_USERNAME="admin"
# Contraseña del super-admin. De momento en TEXTO PLANO (uso personal/dev).
# IMPORTANTE: evita el carácter `$` en la contraseña (Next se lo come al cargar .env).
# Antes de producción se restaurará el hash.
ADMIN_PASSWORD="cambia-esta-contrasena"
